# --------------------------------------------------
# APP
# --------------------------------------------------
APP_NAME=Prime Pizza API
APP_ENV=development
DEBUG=true
# API route prefix (checklists sometimes call this API_PREFIX)
API_V1_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
ALLOWED_HOSTS=["localhost","127.0.0.1"]

# --------------------------------------------------
# SECURITY
# --------------------------------------------------
SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
# Only enable behind a reverse proxy that strips forged XFF from clients.
TRUST_X_FORWARDED_FOR=false
TRUSTED_PROXY_IPS=[]

# --------------------------------------------------
# DATABASE (Neon PostgreSQL)
# --------------------------------------------------
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# --------------------------------------------------
# REDIS (Upstash — use rediss:// for TLS)
# --------------------------------------------------
REDIS_URL=rediss://default:password@host:6379

# --------------------------------------------------
# AUTH RATE LIMITS (Redis)
# --------------------------------------------------
AUTH_LOGIN_LIMIT=10
AUTH_LOGIN_WINDOW_SECONDS=600
AUTH_REGISTER_LIMIT=5
AUTH_REGISTER_WINDOW_SECONDS=600
AUTH_IP_LIMIT=30
AUTH_IP_WINDOW_SECONDS=600

# --------------------------------------------------
# CLOUDINARY
# --------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --------------------------------------------------
# BREVO (transactional email)
# --------------------------------------------------
BREVO_API_KEY=
BREVO_SENDER_NAME=Prime Pizza
BREVO_SENDER_EMAIL=noreply@primepizza.com
EMAIL_ENABLED=true
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_BACKOFF_SECONDS=1.0
EMAIL_BRAND_NAME=Prime Pizza
EMAIL_LOGO_URL=
# Admin recipient for new-order notifications
ADMIN_EMAIL=ShahzainAdnan555@gmail.com
# Contact form destination
CONTACT_RECEIVER_EMAIL=ShahzainAdnan555@gmail.com
# Optional comma-separated additional notification recipients
OWNER_NOTIFICATION_EMAILS=
# Legacy alias (falls back when ADMIN_EMAIL unset in older deploys)
OWNER_EMAIL=ShahzainAdnan555@gmail.com

# --------------------------------------------------
# KITCHEN CHEF (bootstrapped on startup)
# --------------------------------------------------
CHEF_EMAIL=Chef123@gmail.com
CHEF_PASSWORD=Chef123
OWNER_PHONE_NUMBER=

# --------------------------------------------------
# CORS
# --------------------------------------------------
FRONTEND_URL=http://localhost:3000

# --------------------------------------------------
# LOGGING
# --------------------------------------------------
LOG_LEVEL=INFO

# --------------------------------------------------
# HTTP RATE LIMITING (Redis)
# --------------------------------------------------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_OWNER_BYPASS=false
RATE_LIMIT_BYPASS_IPS=[]
RATE_LIMIT_FAIL_CLOSED_POLICIES=["auth","upload","email","orders"]
RATE_LIMIT_DEFAULT_PER_MINUTE=120
RATE_LIMIT_DEFAULT_PER_HOUR=3000
RATE_LIMIT_DEFAULT_BURST=40
RATE_LIMIT_AUTH_PER_MINUTE=20
RATE_LIMIT_AUTH_PER_HOUR=120
RATE_LIMIT_AUTH_BURST=10
RATE_LIMIT_ORDERS_PER_MINUTE=15
RATE_LIMIT_ORDERS_PER_HOUR=100
RATE_LIMIT_ORDERS_BURST=8
RATE_LIMIT_CHECKOUT_PER_MINUTE=30
RATE_LIMIT_CHECKOUT_PER_HOUR=300
RATE_LIMIT_CHECKOUT_BURST=12
RATE_LIMIT_SEARCH_PER_MINUTE=60
RATE_LIMIT_SEARCH_PER_HOUR=1000
RATE_LIMIT_SEARCH_BURST=25
RATE_LIMIT_ADMIN_PER_MINUTE=90
RATE_LIMIT_ADMIN_PER_HOUR=2000
RATE_LIMIT_ADMIN_BURST=30
RATE_LIMIT_UPLOAD_PER_MINUTE=20
RATE_LIMIT_UPLOAD_PER_HOUR=200
RATE_LIMIT_UPLOAD_BURST=8
RATE_LIMIT_EMAIL_PER_MINUTE=10
RATE_LIMIT_EMAIL_PER_HOUR=60
RATE_LIMIT_EMAIL_BURST=5
RATE_LIMIT_HEALTH_PER_MINUTE=180
RATE_LIMIT_HEALTH_PER_HOUR=5000
RATE_LIMIT_HEALTH_BURST=60

# --------------------------------------------------
# DATABASE POOL
# --------------------------------------------------
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30
REDIS_MAX_CONNECTIONS=20

# --------------------------------------------------
# SECURITY HEADERS / DOCS
# --------------------------------------------------
ENABLE_DOCS=true
ENABLE_HSTS=false
HSTS_MAX_AGE_SECONDS=31536000
ENABLE_CSP=true
CONTENT_SECURITY_POLICY=default-src 'none'; frame-ancestors 'none'; base-uri 'none'
MAX_REQUEST_BODY_BYTES=10485760

# --------------------------------------------------
# USER MODULE
# --------------------------------------------------
MAX_ADDRESSES_PER_USER=10
AVATAR_MAX_BYTES=5242880
AVATAR_ALLOWED_CONTENT_TYPES=["image/jpeg","image/png","image/webp","image/gif"]

# --------------------------------------------------
# CATALOG / PRODUCT MODULE
# --------------------------------------------------
MAX_PRODUCT_IMAGES=10
PRODUCT_IMAGE_MAX_BYTES=5242880
CATALOG_CACHE_TTL_SECONDS=300

# --------------------------------------------------
# CART / CHECKOUT PREPARATION
# --------------------------------------------------
CART_CACHE_TTL_SECONDS=120
CART_MIN_ITEM_QUANTITY=1
CART_MAX_ITEM_QUANTITY=20
CART_MAX_ITEMS=50
DELIVERY_FEE_FLAT=150
FREE_DELIVERY_THRESHOLD=2000
TAX_RATE_PERCENT=0
ESTIMATED_PREP_BUFFER_MINUTES=15
ESTIMATED_DELIVERY_MINUTES=45

# --------------------------------------------------
# ORDERS
# --------------------------------------------------
ORDER_CACHE_TTL_SECONDS=120
CHECKOUT_LOCK_TTL_SECONDS=30
ORDER_CANCEL_WINDOW_MINUTES=15

# --------------------------------------------------
# OWNER DASHBOARD
# --------------------------------------------------
DASHBOARD_CACHE_TTL_SECONDS=60
